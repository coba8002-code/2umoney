{
  "$schema": "./rules.schema.json",
  "version": "2.2.0",
  "standardLabels": {
    "KWCAG2.2": "한국형 웹 콘텐츠 접근성 지침 2.2",
    "WCAG2.2": "Web Content Accessibility Guidelines 2.2 (Level AA)"
  },
  "rules": [
    {
      "id": "contrast.text",
      "criterion": "KWCAG 5.3.1 명도 대비 / WCAG 1.4.3 Contrast (Minimum)",
      "standard": ["KWCAG2.2", "WCAG2.2"],
      "auto": true,
      "severity": "serious",
      "fixable": "color",
      "titleKo": "텍스트 명도 대비",
      "titleEn": "Text contrast",
      "params": { "normalRatio": 4.5, "largeRatio": 3.0, "largePx": 18, "largeBoldPx": 14 }
    },
    {
      "id": "contrast.nonText",
      "criterion": "KWCAG 5.3.1 명도 대비 / WCAG 1.4.11 Non-text Contrast",
      "standard": ["KWCAG2.2", "WCAG2.2"],
      "auto": true,
      "severity": "serious",
      "fixable": "color",
      "titleKo": "UI 요소·아이콘 대비",
      "titleEn": "Non-text contrast",
      "params": { "ratio": 3.0 }
    },
    {
      "id": "img.alt",
      "criterion": "KWCAG 5.1.1 적절한 대체 텍스트 / WCAG 1.1.1 Non-text Content",
      "standard": ["KWCAG2.2", "WCAG2.2"],
      "auto": true,
      "severity": "critical",
      "fixable": "ai",
      "titleKo": "이미지 대체텍스트",
      "titleEn": "Image alternative text",
      "params": {}
    },
    {
      "id": "control.label",
      "criterion": "KWCAG 6.4.2 레이블 제공 / WCAG 4.1.2 Name, Role, Value",
      "standard": ["KWCAG2.2", "WCAG2.2"],
      "auto": true,
      "severity": "critical",
      "fixable": "ai",
      "titleKo": "버튼/입력 레이블",
      "titleEn": "Control label",
      "params": {}
    },
    {
      "id": "target.size",
      "criterion": "KWCAG 6.5.1 단일 포인터 입력 지원 / WCAG 2.5.8 Target Size (Minimum)",
      "standard": ["KWCAG2.2", "WCAG2.2"],
      "auto": true,
      "severity": "moderate",
      "fixable": "touchTarget",
      "titleKo": "터치 타깃 크기",
      "titleEn": "Touch target size",
      "params": { "minPx": 44 }
    },
    {
      "id": "text.size",
      "criterion": "KWCAG 본문 가독성 권장 / WCAG 1.4.4 Resize Text (관련)",
      "standard": ["KWCAG2.2"],
      "auto": true,
      "severity": "minor",
      "fixable": "fontSize",
      "titleKo": "최소 글자 크기",
      "titleEn": "Minimum font size",
      "params": { "minBodyPx": 12, "recommendedBodyPx": 16 }
    },
    {
      "id": "focus.visible",
      "criterion": "KWCAG 6.4.1 키보드 사용 보장 / WCAG 2.4.7 Focus Visible",
      "standard": ["KWCAG2.2", "WCAG2.2"],
      "auto": true,
      "severity": "serious",
      "fixable": "focusStyle",
      "titleKo": "포커스 표시",
      "titleEn": "Focus visible",
      "params": {}
    },
    {
      "id": "heading.structure",
      "criterion": "KWCAG 7.1.1 제목 제공 / WCAG 1.3.1 Info and Relationships",
      "standard": ["KWCAG2.2", "WCAG2.2"],
      "auto": false,
      "severity": "moderate",
      "fixable": "none",
      "titleKo": "제목 단계 구조",
      "titleEn": "Heading structure",
      "params": { "maxSkip": 1 }
    }
  ]
}
